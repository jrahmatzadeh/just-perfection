msgid "Popup that appears on the screen when you change the workspace"
msgstr "მხტუნარა, რომელიც ეკრანზე გამოჩნდება, როცა სამუშაო სივრცეს ცვლით"

#: src/data/ui/visibility.ui:313
msgid "Workspace Switcher"
msgstr "სამუშაო სივრცის გადამრთველი"

