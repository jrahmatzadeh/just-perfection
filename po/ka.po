msgid "The icon under window preview in overview"
msgstr "ხატულა ფანჯრის მინიატურის ქვეშ მიმოხილვაში"

#: src/data/ui/behavior.ui:6 src/data/ui/behavior.ui:11
msgid "Behavior"
msgstr "ქცევა"

